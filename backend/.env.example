# Backend Environment Variables
# Copy this file to .env for local development
# Or set these in Render environment variables for production

# JWT Secret Key (generate a random value for production)
# Change this in production!
SECRET_KEY=your-secret-key-change-in-production-abc123xyz789

# JWT Algorithm
ALGORITHM=HS256

# JWT Token Expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Allowed Origins (comma-separated)
# Local development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# For production, set this to your Vercel frontend URL:
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
